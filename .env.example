# Server
LISTEN_ADDR=:8090
API_KEY=your-api-key

# Health Dashboard (internal Docker network)
HEALTH_BASE_URL=http://health-receiver:8080
HEALTH_API_KEY=your-health-api-key
HEALTH_CACHE_TTL=300

# Todoist
TODOIST_TOKEN=your-todoist-token
TODOIST_CACHE_TTL=60

# RSS-Summariser (News)
NEWS_BASE_URL=https://news.example.com
NEWS_LIMIT=5
NEWS_SINCE_HOURS=24
NEWS_CACHE_TTL=900

# Home Assistant
HA_BASE_URL=https://ha.example.com
HA_TOKEN=your-long-lived-token
HA_SENSORS=sensor.co2,sensor.temperature,sensor.humidity
HA_LIGHTS=light.living_room,light.bedroom,light.kitchen
HA_CACHE_TTL=120

# Global fetch timeout per source (seconds)
FETCH_TIMEOUT=15
