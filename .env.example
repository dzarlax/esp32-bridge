# Server
LISTEN_ADDR=:8090

# Health Dashboard (internal Docker network)
HEALTH_BASE_URL=http://health-receiver:8080
HEALTH_API_KEY=your-api-key
HEALTH_CACHE_TTL=300

# Todoist
TODOIST_TOKEN=your-todoist-token
TODOIST_CACHE_TTL=60

# RSS-Summariser (News)
NEWS_BASE_URL=https://news.dzarlax.dev
NEWS_LIMIT=5
NEWS_SINCE_HOURS=24
NEWS_CACHE_TTL=900

# Home Assistant
HA_BASE_URL=https://your-ha-url:8123
HA_TOKEN=your-long-lived-token
HA_SENSORS=sensor.temperature_living_room,sensor.humidity_avocado
HA_CACHE_TTL=120

# Global fetch timeout per source (seconds)
FETCH_TIMEOUT=5
